# ─── Supabase (remoto) ───
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=

# ─── Supabase local (gerados por `supabase start` / `make sb-start`) ───
# Copie os valores exibidos por `supabase status` após o primeiro start
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=<anon key do supabase status>
